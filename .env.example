# DB
POSTGRES_DB=sentinelx_db
POSTGRES_USER=sentinelx
POSTGRES_PASSWORD=changeme
DB_PASSWORD_URLENC=changeme_urlencoded

# Ports
POSTGRES_PORT=5432
BACKEND_PORT=8000

# Paths
UPLOADED_LOGS_DIR=/app/uploaded_logs
GEOIP_COUNTRY_DB_PATH=/geoip/GeoLite2-Country.mmdb
GEOIP_ASN_DB_PATH=/geoip/GeoLite2-ASN.mmdb

# Rules/Enrich
ENRICH_INLINE=1
ENRICH_CACHE_TTL=86400
ENRICH_CACHE_MAX=100000
RULES_RELOAD_SECONDS=600

# Workers
WORKER_POLL_SECONDS=2
WORKER_MAX_PER_CYCLE=1
WORKER_STALE_SECONDS=3600
ENGINE_WORKER_POLL_SECONDS=1
ENGINE_WORKER_MAX_PER_CYCLE=200
ENGINE_WORKER_STALE_SECONDS=3600

# SMTP
SMTP_HOST=sentinelx.tokyo-03.com
SMTP_PORT=587
SMTP_USER=sentinelx@sentinelx.tokyo-03.com
SMTP_PASS=changeme
FROM_EMAIL=sentinelx@sentinelx.tokyo-03.com
SMTP_TIMEOUT_SECONDS=20

# Extra hosts mapping (cPanel + Docker local SMTP)
SENTINELX_SMTP_HOST_ALIAS=sentinelx.tokyo-03.com
SENTINELX_SMTP_HOST_IP=172.17.0.1

# Frontend
FRONTEND_BASE_URL=https://sentinelx.tokyo-03.com/

